---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import CatalogHero from '~/components/widgets/CatalogHero.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import InfoSplitSection from '~/components/widgets/InfoSplitSection.astro';
import { getQuadUrl } from '~/utils/catalog';

const quads = (await getCollection('quad', ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);

const metadata = {
  title: 'Quads BENDA en Belgique | LED Automotive',
  description:
    'Découvrez nos quads BENDA disponibles chez LED Automotive à Fosses-la-Ville, en Belgique. Consultez les modèles, leurs caractéristiques et demandez un essai.',
};

const quadInfoBlocks = [
  {
    title: 'Pourquoi choisir un quad BENDA ?',
    text:
      'Les quads BENDA séduisent par leur style, leur polyvalence et leur positionnement adapté à celles et ceux qui recherchent un véhicule à la fois plaisant à conduire et capable de s’adapter à différents usages. Selon le modèle, vous pouvez profiter d’un quad pensé pour la route, les loisirs ou une utilisation mixte.',
  },
  {
    title: 'Essai quad à Fosses-la-Ville',
    text:
      'Chez LED Automotive, nous vous accueillons en Belgique, à Fosses-la-Ville, pour vous présenter nos quads BENDA et vous aider à trouver le modèle le plus adapté à votre besoin. Vous pouvez consulter les fiches produits, nous contacter pour obtenir plus d’informations ou demander un essai selon les disponibilités.',
  },
  {
    title: 'Vente de quads en Belgique avec accompagnement local',
    text:
      'Notre approche est simple : proposer des quads et équipements fiables, avec un interlocuteur local, disponible et capable de vous conseiller clairement. Cette page vous permet de découvrir les modèles BENDA disponibles, leurs caractéristiques principales et les opportunités en cours.',
  },
];
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <CatalogHero
      eyebrow="Catalogue quads"
      title="Quads BENDA en Belgique"
      intro="Découvrez notre sélection de quads BENDA disponibles chez LED Automotive à Fosses-la-Ville. Consultez les modèles, comparez les caractéristiques et demandez un essai rapidement."
      body="Que vous cherchiez un quad pour la route, le loisir ou un usage plus polyvalent, nous vous accompagnons avec des conseils clairs, un service local et des modèles sélectionnés avec soin."
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {quads.map((quad) => (
    <ProductCard
      href={getQuadUrl(quad)}
      title={quad.data.title}
      image={quad.data.image}
      description={quad.data.excerpt}
      priceLabel={quad.data.priceLabel}
      promoPriceLabel={quad.data.promoPriceLabel}
      badge={quad.data.promo ? 'Promo' : undefined}
      eyebrow="Quad BENDA"
    />
  ))}
</div>
  </section>

  <InfoSplitSection
    blocks={quadInfoBlocks}
    asideEyebrow="Besoin d’un conseil ?"
    asideTitle="Demandez un essai ou plus d’infos"
    asideText="Vous hésitez entre plusieurs quads BENDA ? Nous pouvons vous orienter selon votre usage, votre budget et les modèles disponibles."
    primaryCtaHref="/contact"
    primaryCtaText="Demander un essai"
    secondaryCtaHref="/infos-contact"
    secondaryCtaText="Nous contacter"
  />
</PageLayout>