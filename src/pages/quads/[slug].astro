---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { getQuadUrl } from '~/utils/catalog';

export async function getStaticPaths() {
  const quads = await getCollection('quad', ({ data }) => !data.draft);

  return quads.map((quad) => ({
    params: { slug: quad.data.slug ?? quad.id },
    props: { quad },
  }));
}

const { quad } = Astro.props;
const { Content } = await render(quad);

const metadata = {
  title: quad.data.seo?.title ?? `${quad.data.title} | LED Automotive`,
  description:
    quad.data.seo?.description ??
    quad.data.description ??
    quad.data.excerpt ??
    'Découvrez ce quad disponible chez LED Automotive.',
};

const relatedEntries = (await getCollection('quad', ({ data }) => !data.draft))
  .filter((item) => item.id !== quad.id)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 3);
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <img
          src={quad.data.image}
          alt={quad.data.title}
          class="w-full rounded-2xl border border-gray-800 object-cover"
        />

        {quad.data.gallery && quad.data.gallery.length > 1 && (
          <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {quad.data.gallery.map((image) => (
              <img
                src={image}
                alt={quad.data.title}
                class="h-28 w-full rounded-xl border border-gray-800 object-cover"
              />
            ))}
          </div>
        )}
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-primary">
          {quad.data.brand ?? 'BENDA'}
        </p>

        <h1 class="mt-2 text-4xl font-bold tracking-tight text-white md:text-5xl">
          {quad.data.title}
        </h1>

        {quad.data.excerpt && (
          <p class="mt-4 text-lg text-muted">{quad.data.excerpt}</p>
        )}

        {quad.data.priceLabel && (
          <p class="mt-6 text-3xl font-bold text-primary">{quad.data.priceLabel}</p>
        )}

        <div class="mt-8">
          <a
            href="/contact"
            class="inline-flex rounded-full bg-primary px-6 py-3 font-semibold text-white transition hover:opacity-90"
          >
            {quad.data.ctaLabel ?? 'Demander un essai'}
          </a>
        </div>

        {quad.data.shortSpecs && quad.data.shortSpecs.length > 0 && (
          <div class="mt-10 grid gap-4 sm:grid-cols-2">
            {quad.data.shortSpecs.map((spec) => (
              <div class="rounded-2xl border border-gray-800 bg-black/30 p-4">
                <p class="text-sm text-muted">{spec.label}</p>
                <p class="mt-1 font-semibold text-white">{spec.value}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    {quad.data.description && (
      <section class="mt-16 max-w-4xl">
        <h2 class="text-2xl font-bold text-white">Description</h2>
        <p class="mt-4 text-base leading-8 text-muted">{quad.data.description}</p>
      </section>
    )}

    {quad.data.technicalSpecs && quad.data.technicalSpecs.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white">Caractéristiques techniques</h2>

        <div class="mt-8 grid gap-8 lg:grid-cols-2">
          {quad.data.technicalSpecs.map((section) => (
            <div class="rounded-2xl border border-gray-800 bg-black/30 p-6">
              {section.section && (
                <h3 class="mb-4 text-xl font-semibold text-primary">{section.section}</h3>
              )}

              <div class="space-y-3">
                {section.items.map((item) => (
                  <div class="border-b border-gray-800 pb-3 last:border-b-0">
                    <p class="text-sm text-muted">{item.label}</p>
                    <p class="font-medium text-white">{item.value}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {quad.data.standardEquipment && quad.data.standardEquipment.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white">Équipements de série</h2>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {quad.data.standardEquipment.map((item) => (
            <div class="rounded-2xl border border-gray-800 bg-black/30 p-4 text-white">
              ✓ {item}
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="prose prose-invert mt-16 max-w-4xl">
      <Content />
    </section>

    {relatedEntries.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white">Autres quads</h2>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
          {relatedEntries.map((item) => (
            <a
              href={getQuadUrl(item)}
              class="overflow-hidden rounded-2xl border border-gray-800 bg-black/30 transition hover:border-primary"
            >
              <img src={item.data.image} alt={item.data.title} class="h-56 w-full object-cover" />
              <div class="p-5">
                <h3 class="text-lg font-semibold text-white">{item.data.title}</h3>
                {item.data.priceLabel && (
                  <p class="mt-2 text-primary">{item.data.priceLabel}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>
</PageLayout>