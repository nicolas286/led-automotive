---
import { getCollection, render } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import ProductDetailHero from '~/components/widgets/ProductDetailHero.astro';
import { getQuadUrl, getAccessoryUrl } from '~/utils/catalog';

export async function getStaticPaths() {
  const quads = await getCollection('quad', ({ data }) => !data.draft);

  return quads.map((quad) => ({
    params: { slug: quad.data.slug ?? quad.id },
    props: { quad },
  }));
}

const { quad } = Astro.props;
const { Content } = await render(quad);

const metadata = {
  title: quad.data.seo?.title ?? `${quad.data.title} | LED Automotive`,
  description:
    quad.data.seo?.description ??
    quad.data.description ??
    quad.data.excerpt ??
    'Découvrez ce quad disponible chez LED Automotive.',
};

const relatedEntries = (await getCollection('quad', ({ data }) => !data.draft))
  .filter((item) => item.id !== quad.id)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 3);

  
const compatibleAccessories = (await getCollection('accessory', ({ data }) => !data.draft))
  .filter((item) =>
    item.data.compatibleQuads?.includes(quad.data.slug ?? quad.id)
  )
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <ProductDetailHero
      brand={quad.data.brand ?? 'BENDA'}
      title={quad.data.title}
      excerpt={quad.data.excerpt}
      priceLabel={quad.data.priceLabel}
      promoPriceLabel={quad.data.promoPriceLabel}
      image={quad.data.image}
      gallery={quad.data.gallery ?? []}
      primaryCtaHref="/contact"
      primaryCtaText={quad.data.ctaLabel ?? 'Demander un essai'}
      secondaryCtaHref="/contact"
      secondaryCtaText="Nous contacter"
      shortSpecs={quad.data.shortSpecs ?? []}
    />

        {compatibleAccessories.length > 0 && (
      <section class="mt-8">
        <div class="flex flex-col gap-4 rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6 shadow-[0_18px_40px_rgba(0,0,0,0.18)] md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary">
              Personnalisation
            </p>
            <h2 class="mt-2 text-xl font-bold text-white md:text-2xl">
              Accessoires compatibles disponibles
            </h2>
            <p class="mt-2 text-slate-300">
              Ce quad peut être équipé avec {compatibleAccessories.length} accessoire{compatibleAccessories.length > 1 ? 's' : ''} compatible{compatibleAccessories.length > 1 ? 's' : ''}.
            </p>
          </div>

          <a
            href="#accessoires"
            class="inline-flex items-center justify-center rounded-full border border-primary bg-primary px-5 py-3 text-sm font-semibold text-black transition hover:opacity-90"
          >
            Voir les accessoires
          </a>
        </div>
      </section>
    )}

    {quad.data.description && (
      <section class="mt-16 max-w-4xl">
        <h2 class="text-2xl font-bold text-white md:text-3xl">Description</h2>
        <p class="mt-4 text-base leading-8 text-slate-300">{quad.data.description}</p>
      </section>
    )}

    {quad.data.technicalSpecs && quad.data.technicalSpecs.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white md:text-3xl">
          Caractéristiques techniques
        </h2>

        <div class="mt-8 grid gap-6 lg:grid-cols-2">
          {quad.data.technicalSpecs.map((section) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-6 shadow-[0_18px_40px_rgba(0,0,0,0.18)]">
              {section.section && (
                <h3 class="mb-5 text-xl font-semibold text-primary">
                  {section.section}
                </h3>
              )}

              <div class="space-y-3">
                {section.items.map((item) => (
                  <div class="border-b border-white/10 pb-3 last:border-b-0 last:pb-0">
                    <p class="text-sm text-slate-400">{item.label}</p>
                    <p class="font-medium text-white">{item.value}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {quad.data.standardEquipment && quad.data.standardEquipment.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white md:text-3xl">
          Équipements de série
        </h2>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {quad.data.standardEquipment.map((item) => (
            <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.03] p-4 text-white shadow-[0_18px_40px_rgba(0,0,0,0.18)]">
              ✓ {item}
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="prose prose-invert mt-16 max-w-4xl prose-p:text-slate-300 prose-li:text-slate-300 prose-headings:text-white">
      <Content />
    </section>

        {compatibleAccessories.length > 0 && (
      <section id="accessoires" class="mt-16 scroll-mt-28">
        <h2 class="text-2xl font-bold text-white md:text-3xl">
          Accessoires compatibles
        </h2>

        <p class="mt-4 max-w-3xl text-slate-300">
          Complétez ce quad avec des accessoires et options compatibles sélectionnés pour ce modèle.
        </p>

        <div class="mt-8 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
          {compatibleAccessories.map((item) => (
            <ProductCard
              href={getAccessoryUrl(item)}
              title={item.data.title}
              image={item.data.image}
              description={item.data.excerpt}
              priceLabel={item.data.priceLabel}
              promoPriceLabel={item.data.promoPriceLabel}
              badge={item.data.promo ? 'Promo' : undefined}
              eyebrow="Accessoire"
            />
          ))}
        </div>
      </section>
    )}

    {relatedEntries.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-white md:text-3xl">
          Autres quads
        </h2>

        <div class="mt-8 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
          {relatedEntries.map((item) => (
            <ProductCard
              href={getQuadUrl(item)}
              title={item.data.title}
              image={item.data.image}
              description={item.data.excerpt}
              priceLabel={item.data.priceLabel}
              promoPriceLabel={item.data.promoPriceLabel}
              badge={item.data.promo ? 'Promo' : undefined}
              eyebrow="Quad BENDA"
            />
          ))}
        </div>
      </section>
    )}
  </section>
</PageLayout>