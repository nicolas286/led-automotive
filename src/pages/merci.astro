---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Merci pour votre message | LED Automotive',
  description:
    'Votre demande a bien été envoyée. LED Automotive vous recontacte rapidement pour répondre à votre besoin.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Message envoyé"
    title="Merci, votre demande a bien été envoyée"
    subtitle="Nous avons bien reçu votre message et nous vous recontacterons rapidement, généralement dans la journée."
    callToAction={{
      text: 'Appeler maintenant',
      href: 'tel:+32499610628',
      icon: 'lucide:phone',
      variant: 'primary',
    }}
    callToAction2={{
      text: 'Voir les quads',
      href: '/quads',
    }}
  />

  <section class="not-prose mx-auto max-w-3xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="thankYouBox">
      <h2 class="thankYouTitle">Que se passe-t-il maintenant ?</h2>

      <ul class="thankYouList">
        <li>✔️ Nous analysons votre demande</li>
        <li>✔️ Nous vous recontactons rapidement</li>
        <li>✔️ Nous vous proposons une solution adaptée</li>
      </ul>

      <p class="thankYouText">
        Si votre demande est urgente ou si vous préférez un contact direct,
        vous pouvez nous appeler dès maintenant.
      </p>

      <a href="tel:+32499610628" class="thankYouCall">
        📞 Appeler LED Automotive
      </a>
    </div>
  </section>
</Layout>

<style>
  .thankYouBox {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    text-align: center;
  }

  .thankYouTitle {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
  }

  .thankYouList {
    margin-top: 1.5rem;
    display: grid;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: rgb(203 213 225);
  }

  .thankYouText {
    margin-top: 1.5rem;
    font-size: 0.95rem;
    color: rgb(203 213 225);
  }

  .thankYouCall {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    background: rgb(var(--color-primary, 225 6 0));
    color: white;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .thankYouCall:hover {
    transform: translateY(-1px);
  }
</style>