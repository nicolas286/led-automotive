---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactWidget from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Contact | LED Automotive',
  description:
    'Contactez LED Automotive à Fosses-la-Ville pour un renseignement, un devis ou une demande d’essai de quad BENDA.',
  ignoreTitleTemplate: true,
};

const contactInputs = [
  {
    type: 'text',
    name: 'name',
    label: 'Nom',
    autocomplete: 'name',
    placeholder: 'Votre nom',
  },
  {
    type: 'email',
    name: 'email',
    label: 'Email',
    autocomplete: 'email',
    placeholder: 'votre@email.com',
  },
  {
    type: 'tel',
    name: 'phone',
    label: 'Téléphone',
    autocomplete: 'tel',
    placeholder: 'Votre numéro',
  },
];

const contactTextarea = {
  name: 'message',
  label: 'Message',
  placeholder:
    'Expliquez-nous votre demande : modèle qui vous intéresse, demande d’essai, disponibilité, équipement LED, etc.',
  rows: 6,
};

const infoBlocks = [
  {
    title: 'Un contact simple et direct',
    text: "Vous avez une question sur un quad BENDA, un accessoire LED ou une disponibilité ? Envoyez-nous un message et nous vous répondrons rapidement, avec des infos claires et utiles.",
  },
  {
    title: 'Demande d’essai ou renseignement produit',
    text: "Vous pouvez nous contacter pour demander un essai, obtenir plus d’informations sur un modèle, vérifier une disponibilité ou simplement être conseillé selon votre besoin et votre usage.",
  },
  {
    title: 'Entreprise locale à Fosses-la-Ville',
    text: "Chez LED Automotive, on privilégie le contact humain, la proximité et les échanges simples. Pas de discours compliqué : on vous aide à trouver la bonne solution.",
  },
];
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Une question ? Un essai ? Contactez-nous."
    subtitle="Appelez-nous ou envoyez votre demande via le formulaire."
    callToAction={{
      text: 'Appeler maintenant',
      href: 'tel:+32499610628',
      icon: 'lucide:phone',
      variant: 'primary',
    }}
    callToAction2={{
      text: 'Nous écrire',
      href: '#contact-form',
    }}
  />

  <section class="not-prose mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="contactMainGrid">
      <aside class="contactQuickCard">
        <p class="contactQuickEyebrow">Contact direct</p>
        <h2 class="contactQuickTitle">LED Automotive</h2>
        <p class="contactQuickText">
          Pour un renseignement, un devis ou une demande d’essai.
        </p>

        <div class="contactQuickMeta">
          <p>
            <strong>Téléphone :</strong><br />
            <a href="tel:+32499610628">+32 499 61 06 28</a>
          </p>

          <p>
            <strong>Localisation :</strong><br />
            Fosses-la-Ville
          </p>
        </div>

        <a class="contactPrimaryLink" href="tel:+32499610628">Appeler maintenant</a>
      </aside>

      <div class="contactFormShell">
        <div class="contactFormIntro">
          <p class="contactFormEyebrow">Formulaire</p>
          <h2 class="contactFormTitle">Envoyez-nous votre demande</h2>
          <p class="contactFormText">
            Décrivez simplement votre besoin et nous vous recontactons rapidement.
          </p>
        </div>

        <ContactWidget
          id="contact-form"
          inputs={contactInputs}
          textarea={contactTextarea}
          button="Envoyer la demande"
          disclaimer.label="En nous contactant, vous acceptez que vos données soient utilisées uniquement pour traiter votre demande."
        />
      </div>
    </div>
  </section>

  <section class="not-prose mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <div class="infoBlocksGrid">
      {infoBlocks.map((block) => (
        <article class="infoTextCard">
          <h2 class="infoTextCardTitle">{block.title}</h2>
          <p class="infoTextCardText">{block.text}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .contactMainGrid {
    display: grid;
    gap: 1.5rem;
  }

  .contactQuickCard,
  .contactFormShell,
  .infoTextCard {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 1.5rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .contactQuickCard {
    padding: 1.75rem;
    align-self: start;
  }

  .contactQuickEyebrow,
  .contactFormEyebrow {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-primary, 225 6 0));
  }

  .contactQuickTitle,
  .contactFormTitle {
    margin-top: 0.75rem;
    font-size: 1.75rem;
    line-height: 1.15;
    font-weight: 700;
    color: white;
  }

  .contactQuickText,
  .contactFormText {
    margin-top: 1rem;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgb(203 213 225);
  }

  .contactQuickMeta {
    margin-top: 1.25rem;
    display: grid;
    gap: 1rem;
    color: rgb(203 213 225);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .contactQuickMeta strong {
    color: white;
  }

  .contactQuickMeta a {
    color: rgb(203 213 225);
    text-decoration: none;
  }

  .contactQuickMeta a:hover {
    color: white;
  }

  .contactPrimaryLink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    margin-top: 1.5rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
    background: rgb(var(--color-primary, 225 6 0));
    color: white;
  }

  .contactPrimaryLink:hover {
    transform: translateY(-1px);
  }

  .contactFormShell {
    padding: 1.75rem;
  }

  .contactFormIntro {
    max-width: 42rem;
    margin-bottom: 1.5rem;
  }

  .infoBlocksGrid {
    display: grid;
    gap: 1.5rem;
  }

  .infoTextCard {
    padding: 1.75rem;
  }

  .infoTextCardTitle {
    font-size: 1.35rem;
    line-height: 1.15;
    font-weight: 700;
    color: white;
  }

  .infoTextCardText {
    margin-top: 1rem;
    font-size: 0.98rem;
    line-height: 1.9;
    color: rgb(203 213 225);
  }

  :global(.contactFormShell .max-w-xl) {
    max-width: 100%;
  }

  :global(.contactFormShell .bg-white),
  :global(.contactFormShell .dark\:bg-slate-900) {
    background: transparent !important;
  }

  :global(.contactFormShell .shadow) {
    box-shadow: none !important;
  }

  :global(.contactFormShell .border),
  :global(.contactFormShell .border-gray-200),
  :global(.contactFormShell .dark\:border-gray-700) {
    border: 0 !important;
  }

  :global(.contactFormShell .p-4),
  :global(.contactFormShell .sm\:p-6),
  :global(.contactFormShell .lg\:p-8) {
    padding: 0 !important;
  }

  @media (min-width: 960px) {
    .contactMainGrid {
      grid-template-columns: minmax(320px, 0.9fr) minmax(0, 1.8fr);
      gap: 2rem;
      align-items: start;
    }

    .infoBlocksGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }
  }

  :global(input),
  :global(textarea),
  :global(select) {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.35);
    color: white;
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    outline: none;
    transition: all 0.2s ease;
  }

  :global(input::placeholder),
  :global(textarea::placeholder) {
    color: rgba(255, 255, 255, 0.45);
  }

  :global(input:focus),
  :global(textarea:focus),
  :global(select:focus) {
    border-color: rgb(var(--color-primary, 225 6 0));
    box-shadow: 0 0 0 2px rgba(225, 6, 0, 0.25);
    background: rgba(0, 0, 0, 0.5);
  }

  :global(label) {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
  }

  :global(form > div) {
    margin-bottom: 1rem;
  }
</style>