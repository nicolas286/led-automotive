---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { getQuadUrl, getLedUrl } from '~/utils/catalog';

const quads = await getCollection('quad', ({ data }) => !data.draft && !!data.promo);
const leds = await getCollection('led', ({ data }) => !data.draft && !!data.promo);

const promos = [
  ...quads.map((item) => ({
    type: 'quad',
    title: item.data.title,
    excerpt: item.data.excerpt,
    image: item.data.image,
    priceLabel: item.data.priceLabel,
    href: getQuadUrl(item),
    order: item.data.order ?? 999,
  })),
  ...leds.map((item) => ({
    type: 'led',
    title: item.data.title,
    excerpt: item.data.excerpt,
    image: item.data.image,
    priceLabel: item.data.priceLabel,
    href: getLedUrl(item),
    order: item.data.order ?? 999,
  })),
].sort((a, b) => a.order - b.order);

const metadata = {
  title: 'Offres promo | LED Automotive',
  description:
    'Découvrez les offres promo en cours sur les quads et accessoires chez LED Automotive.',
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">Bons plans</p>
      <h1 class="text-4xl font-bold tracking-tight text-heading md:text-5xl">Offres promo</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Retrouvez ici les produits et véhicules actuellement mis en avant.
      </p>
    </div>

    {promos.length === 0 ? (
      <div class="rounded-2xl border border-gray-800 bg-black/30 p-8 text-muted">
        Aucune promotion en cours pour le moment.
      </div>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        {promos.map((item) => (
          <a
            href={item.href}
            class="group overflow-hidden rounded-2xl border border-gray-800 bg-black/40 transition hover:-translate-y-1 hover:border-primary"
          >
            <img src={item.image} alt={item.title} class="h-64 w-full object-cover" />

            <div class="p-6">
              <div class="flex items-center justify-between gap-4">
                <span class="rounded-full border border-primary px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary">
                  {item.type === 'quad' ? 'Quad' : 'Led'}
                </span>
                <span class="rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
                  Promo
                </span>
              </div>

              <h2 class="mt-4 text-xl font-bold text-white group-hover:text-primary">
                {item.title}
              </h2>

              {item.excerpt && <p class="mt-3 text-sm text-muted">{item.excerpt}</p>}

              {item.priceLabel && (
                <p class="mt-4 text-lg font-semibold text-primary">{item.priceLabel}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</PageLayout>