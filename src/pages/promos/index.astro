---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import CatalogHero from '~/components/widgets/CatalogHero.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import InfoSplitSection from '~/components/widgets/InfoSplitSection.astro';
import { getQuadUrl, getLedUrl } from '~/utils/catalog';

const quads = await getCollection('quad', ({ data }) => !data.draft && !!data.promo);
const leds = await getCollection('led', ({ data }) => !data.draft && !!data.promo);

const promos = [
  ...quads.map((item) => ({
    type: 'quad',
    title: item.data.title,
    excerpt: item.data.excerpt,
    image: item.data.image,
    priceLabel: item.data.priceLabel,
    promoPriceLabel: item.data.promoPriceLabel,
    href: getQuadUrl(item),
    order: item.data.order ?? 999,
  })),
  ...leds.map((item) => ({
    type: 'led',
    title: item.data.title,
    excerpt: item.data.excerpt,
    image: item.data.image,
    priceLabel: item.data.priceLabel,
    promoPriceLabel: item.data.promoPriceLabel,
    href: getLedUrl(item),
    order: item.data.order ?? 999,
  })),
].sort((a, b) => a.order - b.order);

const metadata = {
  title: 'Offres promo en Belgique | LED Automotive',
  description:
    'Découvrez les offres promo en cours sur les quads, leds et accessoires chez LED Automotive à Fosses-la-Ville, en Belgique.',
};

const promoInfoBlocks = [
  {
    title: 'Des offres promo sur une sélection de produits',
    text:
      'Cette page regroupe les quads, leds et accessoires actuellement mis en avant chez LED Automotive. Vous y retrouvez les produits en promotion, les offres ponctuelles et les opportunités disponibles selon les stocks et les arrivages.',
  },
  {
    title: 'Quads et équipements en promotion en Belgique',
    text:
      'Basé à Fosses-la-Ville, LED Automotive propose une sélection de véhicules et équipements avec un service local et des conseils personnalisés. Cette page vous permet d’identifier rapidement les produits concernés par une offre promotionnelle.',
  },
  {
    title: 'Un moyen simple de repérer les bons plans',
    text:
      'Plutôt que de parcourir l’ensemble du catalogue, cette page centralise les offres promo en cours. Vous pouvez ensuite consulter chaque fiche produit pour obtenir plus de détails, voir les caractéristiques et nous contacter rapidement.',
  },
];
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <CatalogHero
      eyebrow="Bons plans"
      title="Offres promo en Belgique"
      intro="Découvrez les quads, leds et accessoires actuellement en promotion chez LED Automotive à Fosses-la-Ville."
      body="Retrouvez ici les produits et véhicules actuellement mis en avant, avec un service local, des conseils personnalisés et une sélection pensée pour un usage concret."
    />

    {promos.length === 0 ? (
      <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-8 text-slate-300 shadow-[0_18px_40px_rgba(0,0,0,0.18)]">
        Aucune promotion en cours pour le moment.
      </div>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {promos.map((item) => (
          <ProductCard
            href={item.href}
            title={item.title}
            image={item.image}
            description={item.excerpt}
            priceLabel={item.priceLabel}
            promoPriceLabel={item.promoPriceLabel}
            badge="Promo"
            eyebrow={item.type === 'quad' ? 'Quad BENDA' : 'Éclairage automobile'}
          />
        ))}
      </div>
    )}
  </section>

  <InfoSplitSection
    blocks={promoInfoBlocks}
    asideEyebrow="Besoin d’un conseil ?"
    asideTitle="Demandez plus d’infos sur une offre"
    asideText="Vous souhaitez en savoir plus sur un quad ou un équipement actuellement en promotion ? Nous pouvons vous renseigner rapidement selon le produit qui vous intéresse."
    primaryCtaHref="/contact"
    primaryCtaText="Nous contacter"
    secondaryCtaHref="/contact"
    secondaryCtaText="Infos de contact"
  />
</PageLayout>