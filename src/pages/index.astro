---
import { getCollection } from 'astro:content';

import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Worlds from '~/components/widgets/Worlds.astro';
import ProductShowcase from '~/components/widgets/ProductShowcase.astro';
import TrustCards from '~/components/widgets/TrustCards.astro';
import Cta from '~/components/widgets/Cta.astro';



const metadata = {
  title: 'Quads BENDA & équipements LED à Fosses-la-Ville | LED Automotive',
  description:
    'Découvrez nos quads BENDA, équipements LED et offres du moment à Fosses-la-Ville. Essais sur demande, conseils personnalisés et matériel fiable.',
  ignoreTitleTemplate: true,
};

const sortByOrder = (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999);

const featuredQuads = (await getCollection('quad', ({ data }) => !data.draft && !!data.featured)).sort(sortByOrder);
const featuredLeds = (await getCollection('led', ({ data }) => !data.draft && !!data.featured)).sort(sortByOrder);

const featuredItems = [
  ...featuredQuads.slice(0, 4).map((item) => ({
    type: 'quad',
    title: item.data.title,
    eyebrow: 'Quad BENDA',
    href: `/quads/${item.data.slug ?? item.id}`,
    image: item.data.image,
    order: item.data.order ?? 999,
  })),
  ...featuredLeds.slice(0, 2).map((item) => ({
    type: 'led',
    title: item.data.title,
    eyebrow: 'Leds & accessoires',
    href: `/leds/${item.data.slug ?? item.id}`,
    image: item.data.image,
    order: item.data.order ?? 999,
  })),
]
  .sort((a, b) => a.order - b.order)
  .slice(0, 6);

const featuredQuadCards = featuredQuads.slice(0, 3).map((item) => ({
  title: item.data.title,
  description: item.data.excerpt ?? item.data.description,
  href: `/quads/${item.data.slug ?? item.id}`,
  image: item.data.image,
  priceLabel: item.data.priceLabel,
  promoPriceLabel: item.data.promoPriceLabel,
  eyebrow: 'Quad BENDA',
  badge: item.data.promo ? 'Promo' : undefined,
}));


const featuredLedCards = featuredLeds.slice(0, 3).map((item) => ({
  title: item.data.title,
  description: item.data.excerpt ?? item.data.description,
  href: `/leds/${item.data.slug ?? item.id}`,
  image: item.data.image,
  priceLabel: item.data.priceLabel,
  promoPriceLabel: item.data.promoPriceLabel,
  eyebrow: 'Leds & accessoires',
  badge: item.data.promo ? 'Promo' : undefined,
}));

const worldsItems = [
  {
    title: 'Quads BENDA',
    description: 'Modèles route et tout-terrain, adaptés au loisir comme à un usage polyvalent.',
    href: '/quads',
    image: '/media/global/quad-fosses.jpg',
    cta: 'Découvrir les quads',
  },
  {
    title: 'Leds & accessoires',
    description: 'Améliorez votre visibilité et équipez votre véhicule avec du matériel fiable.',
    href: '/leds',
    image: '/media/global/led-fosses.png',
    cta: 'Voir les équipements',
  },
  {
    title: 'Offres promo',
    description: 'Opportunités, arrivages et modèles disponibles immédiatement.',
    href: '/promos',
    image:
      '/media/global/quad-benda.jpg',
    cta: 'Voir les promos',
    badge: 'À découvrir',
  },
];

const trustItems = [
  {
    icon: 'lucide:shield-check',
    title: 'Produits sélectionnés',
    description: 'Nous privilégions des équipements fiables, testés et adaptés à un usage concret.',
  },
  {
    icon: 'lucide:map-pinned',
    title: 'Entreprise locale',
    description: 'Un service de proximité avec un interlocuteur accessible et réactif.',
  },
  {
    icon: 'lucide:message-circle-more',
    title: 'Conseils personnalisés',
    description: 'On vous aide à choisir le bon produit selon votre véhicule et votre besoin.',
  },
  {
    icon: 'lucide:wrench',
    title: 'Suivi après achat',
    description: 'Nous restons disponibles après la vente pour vous accompagner si nécessaire.',
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero2
  actions={[
      {
    variant: 'primary',
    text: 'Appeler maintenant',
    href: 'tel:+32499610628',
    icon: 'lucide:phone',
  },
    {
  text: 'Demander un essai',
  href: '/contact',
},
  ]}
  image={{ src: '~/assets/images/led-automotive.jpeg', alt: 'Quads BENDA à Fosses-la-Ville' }}
>
  <Fragment slot="title">
    Prenez le contrôle <br class="hidden xl:inline" />
    <span class="text-accent dark:text-white"> sur route et tout-terrain</span>
  </Fragment>

  <Fragment slot="subtitle">
    <span class="block mb-2 font-semibold">
      Quads BENDA & équipements LED à Fosses-la-Ville
    </span>
    Essai rapide, conseils personnalisés, matériel fiable.
    <br class="hidden sm:inline" />
    Prenez la route ou sortez des sentiers.
  </Fragment>

  <Fragment slot="content">
    {featuredItems.length > 0 && (
      <div class="heroMiniGalleryWrap">
        <div class="heroMiniGalleryHeader">
          <p class="heroMiniGalleryLabel">À découvrir</p>

          <div class="heroMiniGalleryControls">
            <button type="button" class="heroMiniGalleryBtn" data-hero-gallery-prev aria-label="Précédent">
              ←
            </button>
            <button type="button" class="heroMiniGalleryBtn" data-hero-gallery-next aria-label="Suivant">
              →
            </button>
          </div>
        </div>

        <div class="heroMiniGallery" data-hero-gallery>
          {featuredItems.map((item) => (
            <a href={item.href} class="heroMiniCard">
              <img src={item.image} alt={item.title} />
              <div class="heroMiniCardBody">
                <p class="heroMiniCardEyebrow">{item.eyebrow}</p>
                <p class="heroMiniCardTitle">{item.title}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </Fragment>
</Hero2>

 <Worlds items={worldsItems} />

<ProductShowcase
  tagline="Quads à découvrir"
  title="Nos quads à découvrir"
  subtitle="Une sélection de quads BENDA mis en avant."
  items={featuredQuadCards}
  ctaHref="/quads"
  ctaText="Voir tous les quads"
/>

<ProductShowcase
  tagline="Leds à découvrir"
  title="Nos leds & accessoires à découvrir"
  subtitle="Retrouvez une sélection de leds et accessoires mis en avant."
  items={featuredLedCards}
  ctaHref="/leds"
  ctaText="Voir tous les équipements"
/>


<TrustCards
  id="reassurance"
  title="Un service simple, local et fiable"
  subtitle="Basés à Fosses-la-Ville, nous vous offrons des conseils clairs et un suivi de proximité."
  items={trustItems}
/>

<Cta/>
</Layout>
