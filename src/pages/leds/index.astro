---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import { getLedUrl } from '~/utils/catalog';

const leds = (await getCollection('led', ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);

const metadata = {
  title: 'Leds & accessoires | LED Automotive',
  description:
    'Découvrez notre sélection de leds et accessoires automobiles chez LED Automotive à Fosses-la-Ville. Demandez un devis rapidement.',
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">Catalogue</p>
      <h1 class="text-4xl font-bold tracking-tight text-heading md:text-5xl">
        Leds & accessoires
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Retrouvez une sélection de produits ciblés pour l’éclairage et les accessoires automobiles.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
      {leds.map((item) => (
        <a
          href={getLedUrl(item)}
          class="group overflow-hidden rounded-2xl border border-gray-800 bg-black/40 transition hover:-translate-y-1 hover:border-primary"
        >
          <img src={item.data.image} alt={item.data.title} class="h-64 w-full object-cover" />

          <div class="p-6">
            <div class="flex items-start justify-between gap-4">
              <h2 class="text-xl font-bold text-white group-hover:text-primary">
                {item.data.title}
              </h2>
              {item.data.promo && (
                <span class="rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
                  Promo
                </span>
              )}
            </div>

            {item.data.excerpt && <p class="mt-3 text-sm text-muted">{item.data.excerpt}</p>}

            {item.data.priceLabel && (
              <p class="mt-4 text-lg font-semibold text-primary">{item.data.priceLabel}</p>
            )}

            <div class="mt-6 inline-flex items-center text-sm font-medium text-white group-hover:text-primary">
              Voir la fiche
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</PageLayout>