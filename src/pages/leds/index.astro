---
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import CatalogHero from '~/components/widgets/CatalogHero.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import InfoSplitSection from '~/components/widgets/InfoSplitSection.astro';
import { getLedUrl } from '~/utils/catalog';

const leds = (await getCollection('led', ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);

const metadata = {
  title: 'Leds & accessoires en Belgique | LED Automotive',
  description:
    'Découvrez notre sélection de leds et accessoires automobiles chez LED Automotive à Fosses-la-Ville, en Belgique. Consultez les produits disponibles et demandez un devis rapidement.',
};

const ledInfoBlocks = [
  {
    title: 'Pourquoi choisir nos leds et accessoires ?',
    text:
      'Nous sélectionnons des leds et accessoires pensés pour améliorer la visibilité, renforcer le style du véhicule et répondre à un usage concret. Notre objectif est de proposer des produits utiles, fiables et cohérents avec les besoins des automobilistes.',
  },
  {
    title: 'Conseils et accompagnement à Fosses-la-Ville',
    text:
      'Chez LED Automotive, nous vous accompagnons localement pour vous aider à choisir les équipements les plus adaptés à votre véhicule. Que vous cherchiez un éclairage plus performant ou un accessoire spécifique, nous restons disponibles pour vous guider simplement.',
  },
  {
    title: 'Leds automobiles en Belgique avec service local',
    text:
      'Retrouvez chez LED Automotive une sélection de leds et accessoires automobiles disponibles en Belgique. Consultez les fiches produits, découvrez les caractéristiques principales et contactez-nous pour obtenir plus d’informations ou demander un devis.',
  },
];
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <CatalogHero
      eyebrow="Catalogue leds"
      title="Leds & accessoires en Belgique"
      intro="Découvrez notre sélection de leds et accessoires automobiles disponibles chez LED Automotive à Fosses-la-Ville."
      body="Retrouvez des produits ciblés pour l’éclairage et les accessoires automobiles, avec un service local, des conseils personnalisés et une sélection pensée pour un usage concret."
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {leds.map((item) => (
    <ProductCard
      href={getLedUrl(item)}
      title={item.data.title}
      image={item.data.image}
      description={item.data.excerpt}
      priceLabel={item.data.priceLabel}
      promoPriceLabel={item.data.promoPriceLabel}
      badge={item.data.promo ? 'Promo' : undefined}
      eyebrow="Led & accessoire"
    />
  ))}
</div>
  </section>

  <InfoSplitSection
    blocks={ledInfoBlocks}
    asideEyebrow="Besoin d’un conseil ?"
    asideTitle="Demandez un devis ou plus d’infos"
    asideText="Vous hésitez entre plusieurs équipements ? Nous pouvons vous aider à choisir le bon produit selon votre véhicule et votre besoin."
    primaryCtaHref="/contact"
    primaryCtaText="Demander un devis"
    secondaryCtaHref="/contact"
    secondaryCtaText="Nous contacter"
  />
</PageLayout>