---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  body?: string;
}

const {
  eyebrow,
  title,
  intro,
  body,
} = Astro.props;
---

<div class="mb-12 max-w-3xl">
  {eyebrow && (
    <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
      {eyebrow}
    </p>
  )}

  <h1 class="text-4xl font-bold tracking-tight text-heading md:text-5xl">
    {title}
  </h1>

  {intro && (
    <p class="mt-4 text-lg text-muted">
      {intro}
    </p>
  )}

  {body && (
    <p class="mt-4 text-base leading-7 text-muted">
      {body}
    </p>
  )}
</div>