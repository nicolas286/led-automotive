---

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Item {
  title: string;
  description: string;
  href: string;
  image: string | ImageMetadata;
  cta?: string;
  badge?: string;
}

interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  items?: Item[];
}

const {
  id,
  tagline = 'NOS GAMMES',
  title = 'Découvrez nos quads, équipements et offres du moment',
  subtitle = 'Essais sur demande, conseils personnalisés et matériel prêt à l’usage.',
  items = [
    {
      title: 'Quads BENDA',
      description: 'Découvrez nos modèles route et tout-terrain, pensés pour le loisir comme pour un usage polyvalent.',
      href: '/quads',
      image: '/images/home/worlds-quads.jpg',
      cta: 'Découvrir les quads',
    },
    {
      title: 'Leds & accessoires',
      description: 'Retrouvez une sélection ciblée pour améliorer l’éclairage et compléter votre équipement.',
      href: '/leds',
      image: '/images/home/worlds-leds.jpg',
      cta: 'Voir les équipements',
    },
    {
      title: 'Offres promo',
      description: 'Consultez les opportunités, promotions et modèles mis en avant actuellement.',
      href: '/promos',
      image: '/images/home/worlds-promos.jpg',
      cta: 'Voir les promos',
      badge: 'À découvrir',
    },
  ],
} = Astro.props;
---

<section class="not-prose relative" {...id ? { id } : {}}>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      {tagline && (
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-primary">
          {tagline}
        </p>
      )}

      {title && (
        <h2 class="text-4xl font-bold tracking-tight text-white md:text-5xl">
          {title}
        </h2>
      )}

      {subtitle && (
        <p class="mt-4 text-lg leading-8 text-slate-300">
          {subtitle}
        </p>
      )}
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {items.map((item) => (
        <a
          href={item.href}
          class="worldCard group relative overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/[0.03] transition duration-300 hover:-translate-y-1 hover:border-primary/60"
        >
          <div class="worldCardMedia">
  {typeof item.image === 'string' ? (
    <img
      src={item.image}
      alt={item.title}
      width="800"
      height="520"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]"
      loading="lazy"
      decoding="async"
    />
  ) : (
    <Image
      src={item.image}
      alt={item.title}
      width={800}
      height={520}
      sizes="(max-width: 1023px) 100vw, 33vw"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]"
      loading="lazy"
      decoding="async"
    />
  )}

  <div class="worldCardOverlay"></div>

  {item.badge && (
    <span class="absolute left-4 top-4 z-[2] rounded-full border border-white/15 bg-black/55 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white/85 backdrop-blur-sm">
      {item.badge}
    </span>
  )}
</div>

          <div class="relative z-[2] p-6">
            <h3 class="text-2xl font-bold text-white">
              {item.title}
            </h3>

            <p class="mt-3 text-sm leading-7 text-slate-300">
              {item.description}
            </p>

            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white transition group-hover:text-primary">
              <span>{item.cta ?? 'Découvrir'}</span>
              <span aria-hidden="true">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>

    .worldCard::before {
  content: '';
  position: absolute;
  inset: -10%;
  background: radial-gradient(
    circle,
    rgba(225, 6, 0, 0.08),
    transparent 60%
  );
  z-index: 0;
}
  .worldCard {
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .worldCardMedia {
    position: relative;
    height: 260px;
    overflow: hidden;
  }

 .worldCardOverlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      to top,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.12) 55%,
      rgba(0, 0, 0, 0) 100%
    );
  z-index: 1;
}
  .worldCard h3,
  .worldCard p,
  .worldCard .inline-flex {
    position: relative;
    z-index: 2;
  }
  .worldCard img {
  filter: brightness(1.1) contrast(1.05) saturate(1.05);
}
</style>