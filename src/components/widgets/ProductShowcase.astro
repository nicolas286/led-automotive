---
interface Item {
  title: string;
  description?: string;
  href: string;
  image: string;
  priceLabel?: string;
  badge?: string;
  eyebrow?: string;
}

interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  items?: Item[];
  ctaHref?: string;
  ctaText?: string;
}

const {
  id,
  tagline,
  title,
  subtitle,
  items = [],
  ctaHref,
  ctaText,
} = Astro.props;
---

<section class="not-prose relative" {...id ? { id } : {}}>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        {tagline && (
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-primary">
            {tagline}
          </p>
        )}

        {title && (
          <h2 class="text-4xl font-bold tracking-tight text-white md:text-5xl">
            {title}
          </h2>
        )}

        {subtitle && (
          <p class="mt-4 text-lg leading-8 text-slate-300">
            {subtitle}
          </p>
        )}
      </div>

      {ctaHref && ctaText && (
        <div>
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:border-primary/60 hover:text-primary"
          >
            {ctaText}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      )}
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {items.map((item) => (
        <a
          href={item.href}
          class="productCard group overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/[0.02] transition duration-300 hover:-translate-y-1 hover:border-primary/60"
        >
          <div class="productCardMedia">
            <img
              src={item.image}
              alt={item.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]"
              loading="lazy"
            />
            <div class="productCardOverlay"></div>

            {item.badge && (
              <span class="absolute left-4 top-4 z-[2] rounded-full border border-white/15 bg-black/55 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white/85 backdrop-blur-sm">
                {item.badge}
              </span>
            )}
          </div>

          <div class="p-6">
            {item.eyebrow && (
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">
                {item.eyebrow}
              </p>
            )}

            <h3 class="mt-2 text-2xl font-bold text-white">
              {item.title}
            </h3>

            {item.description && (
              <p class="mt-3 text-sm leading-7 text-slate-300">
                {item.description}
              </p>
            )}

            {item.priceLabel && (
              <p class="mt-4 text-lg font-semibold text-primary">
                {item.priceLabel}
              </p>
            )}

            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white transition group-hover:text-primary">
              <span>Voir la fiche</span>
              <span aria-hidden="true">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .productCard {
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .productCardMedia {
    position: relative;
    height: 260px;
    overflow: hidden;
  }

  .productCardOverlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.22) 0%,
      rgba(0, 0, 0, 0.08) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 1;
  }

  .productCard img {
    filter: brightness(1.06) contrast(1.04) saturate(1.04);
  }
</style>