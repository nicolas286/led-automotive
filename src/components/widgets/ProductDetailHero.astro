---
import Button from '~/components/ui/Button.astro';

interface SpecItem {
  label: string;
  value: string;
}

interface Props {
  brand?: string;
  title: string;
  excerpt?: string;
  priceLabel?: string;
  promoPriceLabel?: string;
  image: string;
  gallery?: string[];
  primaryCtaHref?: string;
  primaryCtaText?: string;
  secondaryCtaHref?: string;
  secondaryCtaText?: string;
  shortSpecs?: SpecItem[];
}

const {
  brand,
  title,
  excerpt,
  priceLabel,
  promoPriceLabel,
  image,
  gallery = [],
  primaryCtaHref,
  primaryCtaText,
  secondaryCtaHref,
  secondaryCtaText,
  shortSpecs = [],
} = Astro.props;

const isPromo = !!promoPriceLabel;
const normalizedGallery = [...new Set([image, ...gallery].filter(Boolean))];
const galleryId = `gallery-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<div class="grid gap-10 lg:grid-cols-2 lg:items-start" data-product-gallery-root={galleryId}>
  <div>
    <div class="productDetailMainImage">
      <img
        src={image}
        alt={title}
        class="w-full object-cover"
        data-product-gallery-main
      />
    </div>

    {normalizedGallery.length > 1 && (
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {normalizedGallery.map((galleryImage) => (
          <button
            type="button"
            class:list={[
              'productDetailThumb',
              galleryImage === image && 'productDetailThumbActive',
            ]}
            data-product-gallery-thumb
            data-image-src={galleryImage}
            data-image-alt={title}
            aria-label={`Afficher l’image ${galleryImage}`}
          >
            <img
              src={galleryImage}
              alt={title}
              class="h-28 w-full object-cover"
              loading="lazy"
            />
          </button>
        ))}
      </div>
    )}
  </div>

  <div>
    {brand && (
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary">
        {brand}
      </p>
    )}

    <h1 class="mt-2 text-4xl font-bold tracking-tight text-white md:text-5xl">
      {title}
    </h1>

    {excerpt && (
      <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-300">
        {excerpt}
      </p>
    )}

    {(priceLabel || promoPriceLabel) && (
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {isPromo && priceLabel && (
          <span class="text-lg text-slate-400 line-through md:text-xl">
            {priceLabel}
          </span>
        )}

        <span class="text-3xl font-bold text-primary">
          {promoPriceLabel ?? priceLabel}
        </span>
      </div>
    )}

    {(primaryCtaHref || secondaryCtaHref) && (
      <div class="mt-8 flex flex-wrap gap-4">
        {primaryCtaHref && primaryCtaText && (
          <Button href={primaryCtaHref} variant="primary">
            {primaryCtaText}
          </Button>
        )}

        {secondaryCtaHref && secondaryCtaText && (
          <Button href={secondaryCtaHref}>
            {secondaryCtaText}
          </Button>
        )}
      </div>
    )}

    {shortSpecs.length > 0 && (
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {shortSpecs.map((spec) => (
          <div class="productDetailSpecCard">
            <p class="text-sm text-slate-400">{spec.label}</p>
            <p class="mt-1 font-semibold text-white">{spec.value}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .productDetailMainImage {
    overflow: hidden;
    border-radius: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .productDetailThumb {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    opacity: 0.78;
    transition:
      opacity 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
    cursor: pointer;
    padding: 0;
    appearance: none;
    width: 100%;
    text-align: left;
  }

  .productDetailThumb:hover {
    opacity: 1;
    transform: translateY(-1px);
    border-color: rgba(225, 6, 0, 0.45);
  }

  .productDetailThumbActive {
    opacity: 1;
    border-color: rgba(225, 6, 0, 0.55);
  }

  .productDetailSpecCard {
    border-radius: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    padding: 1rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }
</style>

<script is:inline>
  function initProductGalleries() {
    const galleries = document.querySelectorAll('[data-product-gallery-root]');

    galleries.forEach((gallery) => {
      const mainImage = gallery.querySelector('[data-product-gallery-main]');
      const thumbs = gallery.querySelectorAll('[data-product-gallery-thumb]');

      if (!mainImage || !thumbs.length) return;

      thumbs.forEach((thumb) => {
        if (thumb.dataset.galleryBound === 'true') return;
        thumb.dataset.galleryBound = 'true';

        thumb.addEventListener('click', () => {
          const nextSrc = thumb.getAttribute('data-image-src');
          const nextAlt = thumb.getAttribute('data-image-alt') || '';

          if (!nextSrc) return;

          mainImage.setAttribute('src', nextSrc);
          mainImage.setAttribute('alt', nextAlt);

          thumbs.forEach((item) => item.classList.remove('productDetailThumbActive'));
          thumb.classList.add('productDetailThumbActive');
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductGalleries);
  } else {
    initProductGalleries();
  }

  document.addEventListener('astro:after-swap', initProductGalleries);
</script>