---
import { Icon } from 'astro-icon/components';

interface Props {
  pageUrl: string;
}

const { pageUrl } = Astro.props;

const messengerUrl = `https://m.me/${pageUrl}`;
---

<a
  href={messengerUrl}
  class="messengerFloat"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contacter sur Messenger"
>
  <span class="messengerTooltip">Écrire sur Messenger</span>
  <span class="messengerIconWrap" aria-hidden="true">
    <Icon name="logos:messenger" class="messengerIcon" />
  </span>
</a>

<style>
  .messengerFloat {
    position: fixed;
    right: 1rem;
    bottom: 5.2rem; /* 👈 au-dessus du bouton WhatsApp */
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .messengerTooltip {
    display: none;
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    background: rgba(10, 10, 10, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: white;
    font-size: 0.9rem;
    line-height: 1;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.28);
    white-space: nowrap;
  }

  .messengerIconWrap {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1877f2, #a033ff);
    box-shadow:
      0 12px 30px rgba(24, 119, 242, 0.28),
      0 4px 12px rgba(0, 0, 0, 0.24);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      filter 0.2s ease;
  }

  .messengerIcon {
    width: 1.4rem;
    height: 1.4rem;
    color: white;
  }

  .messengerFloat:hover .messengerIconWrap {
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      0 16px 36px rgba(24, 119, 242, 0.34),
      0 6px 14px rgba(0, 0, 0, 0.26);
    filter: brightness(1.04);
  }

  .messengerFloat:hover .messengerTooltip {
    display: inline-flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .messengerFloat {
      right: 0.85rem;
      bottom: 4.7rem; /* ajusté mobile */
    }

    .messengerTooltip {
      display: none !important;
    }

    .messengerIconWrap {
      width: 3.25rem;
      height: 3.25rem;
    }
  }
</style>