---
import '@fontsource-variable/inter';
import '@fontsource/oswald';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Oswald';

    --aw-color-primary: rgb(225 6 0);         /* rouge principal */
    --aw-color-secondary: rgb(184 0 0);       /* rouge foncé */
    --aw-color-accent: rgb(255 255 255);      /* accent clair */

    --aw-color-text-heading: rgb(13 13 13);
    --aw-color-text-default: rgb(26 26 26);
    --aw-color-text-muted: rgb(26 26 26 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(13 13 13);

    ::selection {
      background-color: rgb(225 6 0);
      color: rgb(255 255 255);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Oswald';

    --aw-color-primary: rgb(225 6 0);
    --aw-color-secondary: rgb(184 0 0);
    --aw-color-accent: rgb(255 255 255);

    --aw-color-text-heading: rgb(255 255 255);
    --aw-color-text-default: rgb(230 230 230);
    --aw-color-text-muted: rgb(191 191 191 / 78%);
    --aw-color-bg-page: rgb(13 13 13);

    ::selection {
      background-color: rgb(225 6 0);
      color: rgb(255 255 255);
    }
  }
</style>